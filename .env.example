# ===========================================
# 공시가격 간편 조회 — 환경변수 예시
# ===========================================
# 이 파일을 .env.local 로 복사한 뒤 실제 키 값을 입력하세요.
# .env.local 파일은 .gitignore에 포함되어 git에 커밋되지 않습니다.

# 공공데이터포털 서비스 키
# 발급: https://www.data.go.kr
#   - 국토교통부_개별주택가격정보 서비스
#   - 국토교통부_공동주택가격정보 서비스
#   - 국토교통부_개별공시지가정보 서비스
DATA_GO_KR_KEY=여기에_공공데이터포털_서비스키_입력

# VWorld (브이월드) API 키 (지번주소 → 법정동코드 변환용)
# 발급: https://www.vworld.kr
VWORLD_KEY=여기에_VWorld_인증키_입력

# MOCK 모드: true로 두면 API 호출 없이 샘플 데이터 반환 (UI 테스트용)
# 실제 운영 시 false 또는 미설정
MOCK_MODE=true
